<odoo>

    <record model="ir.ui.view" id="product_variant_view_inherit">
        <field name="name">product.product.view</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="Custom Price">

                    <group>
                        <group>
                            <field name="custom_price"/>

                            <field name="min_custom_price"
                                   widget="radio"
                                   invisible="not custom_price "/>

                            <field name="min_fixed_price"
                                   invisible="(not custom_price or min_custom_price != 'fixed')"/>
                        </group>

                            <group>
                                <div>
                                    <label for="min_percent_price" string="Set Minimum Percentage" class ="fw-bold text-nowrap my-2 "   invisible="(not custom_price or min_custom_price != 'percent')"/>

                                        <field name="min_percent_price"
                                               class = "oe_inline"
                                               invisible="(not custom_price or min_custom_price != 'percent')"/>

                                         <field name="estimated_price"
                                                class="oe_inline"
                                                invisible="(not custom_price or min_custom_price != 'percent' or not min_percent_price)"
                                                readonly="1"/>
                                </div>
                            </group>
                    </group>

                </page>

            </xpath>

        </field>

    </record>

</odoo>